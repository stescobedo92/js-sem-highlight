# =============================================================================
# Rust / Cargo
# =============================================================================

# Build artifacts (workspace `target/` and any per-crate `target/`).
/target
**/target

# Cargo backup files (created by certain `cargo` operations).
**/*.rs.bk
Cargo.lock.bak

# `cargo install` artifacts.
.cargo/

# Coverage / profiling outputs.
*.profraw
tarpaulin-report.html
/coverage
/lcov.info

# `dhat` heap-profile dumps land in the working directory by default.
# Specific reports we choose to keep live under `docs/` (committed manually).
dhat-heap.json
**/dhat-heap-*.json
!docs/dhat-heap-*.json

# Criterion benchmark output (regenerated each run).
**/criterion/

# =============================================================================
# Node / TypeScript / VS Code extension
# =============================================================================

# Dependencies and compiled output.
client/node_modules/
client/out/
client/dist/

# Packaged extension (regenerated by `vsce package`).
client/*.vsix

# Cache from `@vscode/test-electron` (downloads a full VS Code build, ~200 MB).
client/.vscode-test/
client/.vscode-test-web/

# Cross-compiled binaries staged for `.vsix` packaging.
# These are reproducible artifacts produced by `cargo build --target ...`
# or `scripts/package-extension.sh`; CI re-creates them on every release tag.
client/server/

# npm / pnpm / yarn debug output.
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =============================================================================
# Release artifacts
# =============================================================================

# Local staging directories used by the release workflow when run by hand.
/dist
/release-files
*.tar.gz
*.zip
*.sha256

# =============================================================================
# Local tooling caches and scratch space
# =============================================================================

# Cloned repos for the bug-bash harness.
.bug-bash/

# Logs, PIDs, env files.
*.log
*.pid
.env
.env.local
.env.*.local

# =============================================================================
# Editor / IDE / OS
# =============================================================================

.idea/
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json

.DS_Store
Thumbs.db
desktop.ini

# =============================================================================
# Tooling integrations (NOT versioned)
# =============================================================================

# Claude Code per-project state (skills, sessions, transcripts).
.claude/

# OpenSpec workflow artifacts (proposals, designs, specs, archive).
# Kept LOCAL only by user preference; the project does not version specs.
openspec/
